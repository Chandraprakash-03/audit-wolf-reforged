# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration (Supabase)
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# AI Analysis Configuration
OPENROUTER_API_KEY=your-openrouter-key
LANGCHAIN_API_KEY=your-langchain-key

# Email Service Configuration (Senderwolf)
SENDERWOLF_API_KEY=your_senderwolf_api_key
SENDERWOLF_FROM_EMAIL=senderwolf-from-email

# IPFS Configuration (Pinata)
IPFS_GATEWAY_URL=https://ipfs.io/ipfs/
PINATA_JWT=your_pinata_jwt_token
PINATA_GATEWAY_URL=gateway.pinata.cloud

# Blockchain Configuration
ETHEREUM_RPC_URL=your_ethereum_rpc_url
POLYGON_RPC_URL=your_polygon_rpc_url
PRIVATE_KEY=your_private_key
AUDIT_REGISTRY_CONTRACT_ADDRESS=your_deployed_contract_address
GAS_LIMIT=500000
GAS_PRICE=20

# Redis Configuration (for job queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Performance and Caching Configuration
CACHE_AUDIT_TTL=3600
CACHE_REPORT_TTL=86400
CACHE_USER_TTL=1800
CACHE_MAX_SIZE_MB=100

# CDN Configuration
CDN_ENABLED=false
CDN_BASE_URL=
CDN_CACHE_TTL=86400
CDN_COMPRESSION=true
CDN_VERSIONING=true

# Admin Configuration
ADMIN_EMAILS=admin@example.com

# WebSocket Configuration
FRONTEND_URL=http://localhost:3000

# Security
JWT_SECRET=your_jwt_secret
ENCRYPTION_KEY=your_encryption_key
# Error Tracking and Monitoring
SENTRY_DSN=your_sentry_dsn_here
LOG_LEVEL=info

# Health Check Configuration
HEALTH_CHECK_TIMEOUT=5000
DISK_USAGE_WARNING_THRESHOLD=80
DISK_USAGE_CRITICAL_THRESHOLD=90
MEMORY_USAGE_WARNING_THRESHOLD=80
MEMORY_USAGE_CRITICAL_THRESHOLD=90